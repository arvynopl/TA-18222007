# .streamlit/secrets.toml.example
#
# Copy this file to .streamlit/secrets.toml for LOCAL development, OR paste
# the contents into the "Secrets" panel of your Streamlit Community Cloud app
# (App settings -> Secrets) for production. NEVER commit .streamlit/secrets.toml
# - it is already covered by .gitignore.
#
# Streamlit injects each top-level key as an environment variable at runtime,
# so these values are read by config.py via os.environ.get().
#
# Required for production deployment:
#   CDT_DATABASE_URL — Postgres connection string (Neon free tier recommended).
#   Forms accepted: postgres://..., postgresql://..., postgresql+psycopg2://...
#   The connection.py module normalises all three to the psycopg2 driver form.
#
# If CDT_DATABASE_URL is unset on Streamlit Cloud, app.py refuses to start
# (silent SQLite-data-loss prevention).

CDT_DATABASE_URL = "postgresql://<user>:<password>@<host>.neon.tech/<dbname>?sslmode=require"

# Optional overrides (uncomment if needed):
# CDT_BCRYPT_ROUNDS = "12"
# CDT_DEBUG = "0"
